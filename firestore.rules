rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone authenticated can read; only the owner can write
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Conversations: role-aware access for groups
    match /conversations/{convoId} {
      function existing() { return resource.data; }
      function incoming() { return request.resource.data; }
      function isMember() {
        return request.auth != null && request.auth.uid in existing().members;
      }
      function isAdmin() {
        return request.auth != null && request.auth.uid == existing().get('createdBy', '');
      }
      function isModerator() {
        return request.auth != null && request.auth.uid in existing().get('moderators', []);
      }
      function changedKeys() {
        return incoming().diff(existing()).affectedKeys();
      }
      function sameCreator() {
        return incoming().get('createdBy', '') == existing().get('createdBy', '');
      }

      allow read: if isMember();

      // Any signed-in user can create a conversation they are a member of
      allow create: if request.auth != null
        && request.auth.uid in incoming().members;

      // Only the group admin (creator) can delete the whole conversation
      allow delete: if isAdmin();

      allow update: if isMember() && (
        // 1. Sending a message / typing — only these fields may change
        changedKeys().hasOnly(['lastMessage', 'typing'])

        // 2. Admin or moderator adds members (no removals, creator preserved)
        || ((isAdmin() || isModerator())
            && incoming().members.hasAll(existing().members)
            && sameCreator())

        // 3. Admin manages moderators, renames, or removes members (creator preserved)
        || (isAdmin() && sameCreator())

        // 4. Any member removes only themselves (leave group)
        || (existing().members.hasAll(incoming().members)
            && !(request.auth.uid in incoming().members)
            && changedKeys().hasOnly(['members', 'moderators']))
      );

      match /messages/{msgId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.members;
      }
    }
  }
}
